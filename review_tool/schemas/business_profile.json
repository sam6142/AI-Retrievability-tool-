{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BusinessProfile",
  "$ref": "#/definitions/BusinessProfile",
  "definitions": {
    "BusinessProfile": {
      "type": "object",
      "required": ["business_type", "inferred_services", "inferred_attributes", "inferred_customer_contexts", "confidence", "notes"],
      "additionalProperties": false,
      "properties": {
        "business_type": {"type": "string", "minLength": 1},
        "inferred_services": {"type": "array", "items": {"type": "string"}},
        "inferred_attributes": {"type": "array", "items": {"type": "string"}},
        "inferred_customer_contexts": {"type": "array", "items": {"type": "string"}},
        "confidence": {"type": "string", "enum": ["high", "medium", "low"]},
        "notes": {"type": "string"}
      }
    }
  }
}
